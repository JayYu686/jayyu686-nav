---
import resources from '../data/resources.json';

const categories = ['全部', ...new Set(resources.map((item) => item.category))];

const getDomain = (url) => {
  try {
    return new URL(url).hostname;
  } catch (e) {
    return '';
  }
};
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>JayYu 资源导航</title>
    <meta name="description" content="收录常用工具、VPS、域名、学术资源和程序员网站。" />
    <style>
      :root {
        --panel: rgba(18, 26, 43, 0.55);
        --panel-active: rgba(255, 255, 255, 0.12);
        --text: #f0f6fc;
        --muted: #8b949e;
        --line: rgba(255, 255, 255, 0.08);
        --accent: #58a6ff;
        --accent-hover: #79c0ff;
        --gradient: linear-gradient(135deg, #58a6ff 0%, #00f2fe 100%);
      }

      * { box-sizing: border-box; }
      
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
        background-color: #0b1020;
        color: var(--text);
        min-height: 100vh;
        overflow-x: hidden;
      }

      .aurora-bg {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        z-index: -1;
        overflow: hidden;
        background: #0b1020;
      }

      .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.5;
        animation: float 20s infinite ease-in-out alternate;
      }

      .orb-1 {
        width: 60vw; height: 60vh;
        background: radial-gradient(circle, #0e5a9c, transparent 60%);
        top: -10%; left: -10%;
        animation-delay: 0s;
      }

      .orb-2 {
        width: 50vw; height: 50vh;
        background: radial-gradient(circle, #5b28a2, transparent 60%);
        bottom: -10%; right: -10%;
        animation-delay: -5s;
        animation-duration: 25s;
      }

      .orb-3 {
        width: 70vw; height: 70vh;
        background: radial-gradient(circle, #028e96, transparent 60%);
        top: 30%; left: 40%;
        animation-delay: -10s;
        animation-duration: 22s;
      }

      @keyframes float {
        0% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(30px, -50px) scale(1.1); }
        66% { transform: translate(-20px, 20px) scale(0.9); }
        100% { transform: translate(0, 0) scale(1); }
      }

      .wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 60px 24px 80px;
      }

      .hero {
        margin-bottom: 40px;
        text-align: center;
      }

      h1 {
        font-size: 48px;
        font-weight: 800;
        margin: 0 0 16px;
        background: var(--gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -0.5px;
      }

      .sub {
        color: var(--muted);
        font-size: 18px;
        line-height: 1.6;
        max-width: 600px;
        margin: 0 auto;
      }

      .toolbar {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        margin: 40px 0;
      }

      .search {
        width: 100%;
        max-width: 600px;
        padding: 16px 24px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        color: var(--text);
        font-size: 16px;
        transition: all 0.3s ease;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
      }

      .search:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 8px 32px rgba(88, 166, 255, 0.2);
        background: rgba(0, 0, 0, 0.6);
      }

      .filters {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
      }

      .filter {
        border: 1px solid var(--line);
        background: var(--panel);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        color: var(--text);
        border-radius: 999px;
        padding: 8px 18px;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.3s ease;
      }

      .filter:hover {
        background: var(--panel-active);
        border-color: rgba(255, 255, 255, 0.2);
        transform: translateY(-1px);
      }

      .filter.active {
        background: var(--gradient);
        color: #000;
        border-color: transparent;
        font-weight: 600;
        box-shadow: 0 4px 12px rgba(88, 166, 255, 0.25);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
        perspective: 1000px;
      }

      .card {
        background: var(--panel);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 24px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        display: flex;
        flex-direction: column;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
        animation: fadeInUp 0.6s ease-out both;
        will-change: transform, opacity;
      }

      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(88, 166, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
        background: rgba(24, 34, 55, 0.7);
        z-index: 2;
      }

      .card-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
      }

      .icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.9);
        padding: 4px;
        object-fit: contain;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
      }

      .card h2 {
        margin: 0;
        font-size: 20px;
        font-weight: 600;
        line-height: 1.3;
      }

      .card a {
        color: var(--text);
        text-decoration: none;
        display: inline-block;
        transition: color 0.2s;
      }

      .card a:hover {
        color: var(--accent);
      }

      .meta {
        color: var(--accent);
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .summary {
        line-height: 1.6;
        color: #c9d1d9;
        margin-bottom: 16px;
        font-size: 15px;
        flex-grow: 1;
      }

      .note {
        font-size: 14px;
        color: #a5b4fc;
        line-height: 1.6;
        background: rgba(0, 0, 0, 0.25);
        padding: 12px;
        border-radius: 12px;
        margin-bottom: 16px;
        border-left: 3px solid var(--accent);
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: auto;
      }

      .tag {
        font-size: 12px;
        border-radius: 6px;
        padding: 4px 10px;
        background: rgba(255, 255, 255, 0.08);
        color: #c9d1d9;
        border: 1px solid transparent;
        transition: all 0.2s ease;
      }

      .tag:hover {
        border-color: rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.12);
      }

      footer {
        margin-top: 60px;
        text-align: center;
        color: var(--muted);
        font-size: 14px;
        padding-top: 24px;
        border-top: 1px solid var(--line);
      }
    </style>
  </head>

  <body>
    <div class="aurora-bg">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>

    <main class="wrap">
      <section class="hero">
        <h1>JayYu 资源导航</h1>
        <p class="sub">
          收录我常用的工具、VPS、域名服务、学术资源和程序员网站，
          并逐步补充使用心得、避坑记录和轻评测。
        </p>
      </section>

      <section class="toolbar">
        <input id="search" class="search" type="text" placeholder="搜索资源、标签、分类..." />

        <div class="filters">
          {categories.map((category) => (
            <button
              class={`filter ${category === '全部' ? 'active' : ''}`}
              data-filter={category}
            >
              {category}
            </button>
          ))}
        </div>
      </section>

      <section id="grid" class="grid">
        {resources.map((item, index) => (
          <article
            class="card"
            style={`animation-delay: ${Math.min(index * 0.05, 1)}s`}
            data-category={item.category}
            data-search={`${item.title} ${item.category} ${item.summary} ${item.tags.join(' ')} ${item.note || ''}`.toLowerCase()}
          >
            <div class="card-header">
              <img class="icon" src={`https://www.google.com/s2/favicons?domain=${getDomain(item.url)}&sz=128`} alt={item.title} loading="lazy" />
              <h2>
                <a href={item.url} target="_blank" rel="noreferrer">{item.title}</a>
              </h2>
            </div>
            <div class="meta">{item.category}</div>
            <div class="summary">{item.summary}</div>
            {item.note && <div class="note">🌟 {item.note}</div>}
            <div class="tags">
              {item.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </article>
        ))}
      </section>

      <footer>
        © 2026 JayYu · 持续更新中
      </footer>
    </main>

    <script>
      const input = document.getElementById('search');
      const buttons = Array.from(document.querySelectorAll('.filter'));
      const cards = Array.from(document.querySelectorAll('.card'));

      let activeCategory = '全部';

      function applyFilters() {
        const keyword = (input.value || '').trim().toLowerCase();

        cards.forEach((card) => {
          const category = card.dataset.category || '';
          const searchText = card.dataset.search || '';

          const matchCategory =
            activeCategory === '全部' || category === activeCategory;
          const matchKeyword =
            keyword === '' || searchText.includes(keyword);

          card.style.display = matchCategory && matchKeyword ? 'block' : 'none';
        });
      }

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          buttons.forEach((b) => b.classList.remove('active'));
          button.classList.add('active');
          activeCategory = button.dataset.filter || '全部';
          applyFilters();
        });
      });

      input.addEventListener('input', applyFilters);
    </script>
  </body>
</html>
