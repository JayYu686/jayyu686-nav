---
import HomeContent from '../components/HomeContent.astro';
import { buildHomePageData } from '../lib/homePageData';
import { zhMessages } from '../i18n/zh';
const { categories, resourcesByCategory } = await buildHomePageData(zhMessages, 'zh');
---

<HomeContent
  messages={zhMessages}
  categories={categories}
  resourcesByCategory={resourcesByCategory}
  languageSwitchHref="/en/"
/>
