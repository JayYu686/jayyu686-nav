---
import resources from '../data/resources.json';

const categories = ['全部', ...new Set(resources.map((item) => item.category))];
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>JayYu 资源导航</title>
    <meta name="description" content="收录常用工具、VPS、域名、学术资源和程序员网站。" />
    <style>
      :root {
        --bg: #0b1020;
        --panel: #121a2b;
        --panel-2: #18233a;
        --text: #e9eefb;
        --muted: #9fb0d1;
        --line: #26314d;
        --accent: #7aa2ff;
        --accent-hover: #5a88ff;
      }

      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "PingFang SC",
          "Segoe UI", sans-serif;
        background: var(--bg);
        background-image: radial-gradient(circle at 50% 0%, rgba(122, 162, 255, 0.1) 0%, transparent 50%);
        color: var(--text);
        min-height: 100vh;
      }

      .wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 60px 24px 80px;
      }

      .hero {
        margin-bottom: 40px;
        text-align: center;
      }

      h1 {
        font-size: 48px;
        font-weight: 800;
        margin: 0 0 16px;
        background: linear-gradient(135deg, #fff, var(--accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .sub {
        color: var(--muted);
        font-size: 18px;
        line-height: 1.6;
        max-width: 600px;
        margin: 0 auto;
      }

      .toolbar {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        margin: 40px 0;
      }

      .search {
        width: 100%;
        max-width: 600px;
        padding: 16px 24px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: var(--panel);
        color: var(--text);
        font-size: 16px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
      }

      .search:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 4px 24px rgba(122, 162, 255, 0.15);
        background: #151e32;
      }

      .filters {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
      }

      .filter {
        border: 1px solid var(--line);
        background: var(--panel);
        color: var(--text);
        border-radius: 999px;
        padding: 8px 18px;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.2s ease;
      }

      .filter:hover {
        background: var(--panel-2);
        border-color: var(--muted);
      }

      .filter.active {
        background: var(--accent);
        color: #08111f;
        border-color: var(--accent);
        font-weight: 600;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
      }

      .card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 24px;
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
        display: flex;
        flex-direction: column;
      }

      .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
        border-color: #3b4b73;
      }

      .card h2 {
        margin: 0 0 12px;
        font-size: 22px;
        font-weight: 600;
      }

      .card a {
        color: var(--text);
        text-decoration: none;
        display: inline-block;
      }

      .card a:hover {
        color: var(--accent);
      }

      .meta {
        color: var(--accent);
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .summary {
        line-height: 1.6;
        color: #d8e0f4;
        margin-bottom: 16px;
        font-size: 15px;
        flex-grow: 1;
      }

      .note {
        font-size: 14px;
        color: var(--muted);
        line-height: 1.6;
        background: rgba(0, 0, 0, 0.2);
        padding: 12px;
        border-radius: 12px;
        margin-bottom: 16px;
        border-left: 3px solid var(--accent);
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: auto;
      }

      .tag {
        font-size: 12px;
        border-radius: 6px;
        padding: 4px 10px;
        background: var(--panel-2);
        color: #cfe0ff;
        border: 1px solid transparent;
        transition: border-color 0.2s ease;
      }

      .tag:hover {
        border-color: var(--line);
      }

      footer {
        margin-top: 60px;
        text-align: center;
        color: var(--muted);
        font-size: 14px;
        padding-top: 24px;
        border-top: 1px solid var(--line);
      }
    </style>
  </head>

  <body>
    <main class="wrap">
      <section class="hero">
        <h1>JayYu 资源导航</h1>
        <p class="sub">
          收录我常用的工具、VPS、域名服务、学术资源和程序员网站，
          并逐步补充使用心得、避坑记录和轻评测。
        </p>
      </section>

      <section class="toolbar">
        <input id="search" class="search" type="text" placeholder="搜索资源、标签、分类..." />

        <div class="filters">
          {categories.map((category) => (
            <button
              class={`filter ${category === '全部' ? 'active' : ''}`}
              data-filter={category}
            >
              {category}
            </button>
          ))}
        </div>
      </section>

      <section id="grid" class="grid">
        {resources.map((item) => (
          <article
            class="card"
            data-category={item.category}
            data-search={`${item.title} ${item.category} ${item.summary} ${item.tags.join(' ')} ${item.note || ''}`.toLowerCase()}
          >
            <h2>
              <a href={item.url} target="_blank" rel="noreferrer">{item.title}</a>
            </h2>
            <div class="meta">{item.category}</div>
            <div class="summary">{item.summary}</div>
            {item.note && <div class="note">🌟 {item.note}</div>}
            <div class="tags">
              {item.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </article>
        ))}
      </section>

      <footer>
        © 2026 JayYu · 持续更新中
      </footer>
    </main>

    <script>
      const input = document.getElementById('search');
      const buttons = Array.from(document.querySelectorAll('.filter'));
      const cards = Array.from(document.querySelectorAll('.card'));

      let activeCategory = '全部';

      function applyFilters() {
        const keyword = (input.value || '').trim().toLowerCase();

        cards.forEach((card) => {
          const category = card.dataset.category || '';
          const searchText = card.dataset.search || '';

          const matchCategory =
            activeCategory === '全部' || category === activeCategory;
          const matchKeyword =
            keyword === '' || searchText.includes(keyword);

          card.style.display = matchCategory && matchKeyword ? 'block' : 'none';
        });
      }

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          buttons.forEach((b) => b.classList.remove('active'));
          button.classList.add('active');
          activeCategory = button.dataset.filter || '全部';
          applyFilters();
        });
      });

      input.addEventListener('input', applyFilters);
    </script>
  </body>
</html>