---
import HomeContent from '../../components/HomeContent.astro';
import { buildHomePageData } from '../../lib/homePageData';
import { enMessages } from '../../i18n/en';
const { categories, resourcesByCategory } = await buildHomePageData(enMessages, 'en');
---

<HomeContent
  messages={enMessages}
  categories={categories}
  resourcesByCategory={resourcesByCategory}
  languageSwitchHref="/"
/>
