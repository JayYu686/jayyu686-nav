---
import { getCollection } from 'astro:content';
import HomeContent from '../../components/HomeContent.astro';
import { enMessages } from '../../i18n/en';
import resourcesJson from '../../content/resources/resources.json';

interface ResourceRecord {
  title: string;
  summary: string;
  url: string;
  category: string;
  title_en?: string;
  summary_en?: string;
}

interface FilterCategory {
  value: string;
  label: string;
}

const entries = await getCollection('resources');
const fallbackItems = ((resourcesJson as { items?: ResourceRecord[]; resources?: { items?: ResourceRecord[] } }).resources?.items ??
  (resourcesJson as { items?: ResourceRecord[] }).items ??
  []) as ResourceRecord[];

const rawItems: ResourceRecord[] = entries.length > 0
  ? entries.map((entry) => entry.data as ResourceRecord)
  : fallbackItems;

const localizedItems = rawItems.map((item) => ({
  ...item,
  title: item.title_en || item.title,
  summary: item.summary_en || item.summary,
  searchableName: [item.title_en, item.title, item.summary_en, item.summary].filter(Boolean).join(' '),
}));

const categoryKeys: string[] = [...new Set(localizedItems.map((item) => item.category))];
const categories: FilterCategory[] = [
  { value: enMessages.ui.allCategory, label: enMessages.ui.allCategory },
  ...categoryKeys.map((key) => ({ value: key, label: enMessages.categoryNames[key] ?? key })),
];

const resourcesByCategory = categoryKeys.map((category, index) => {
  const items = localizedItems.filter((item) => item.category === category);
  return {
    id: `cat-${index + 1}`,
    category,
    categoryLabel: enMessages.categoryNames[category] ?? category,
    countLabel: `${items.length} ${enMessages.ui.siteCount}`,
    items,
  };
});
---

<HomeContent
  messages={enMessages}
  categories={categories}
  resourcesByCategory={resourcesByCategory}
  languageSwitchHref="/"
/>
