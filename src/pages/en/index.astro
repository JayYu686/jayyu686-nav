---
import { getCollection } from 'astro:content';
import HomeContent from '../../components/HomeContent.astro';
import { enMessages } from '../../i18n/en';
import resourcesJson from '../../content/resources/resources.json';

interface ResourceRecord {
  title: string;
  summary: string;
  url: string;
  category: string;
  subcategory?: string;
  subcategory_en?: string;
  title_en?: string;
  summary_en?: string;
}

interface FilterCategory {
  value: string;
  label: string;
}

const RECENT_CATEGORY = 'Recent Updates';
const RECENT_LIMIT = 16;

const entries = await getCollection('resources');
const fallbackItems = ((resourcesJson as { items?: ResourceRecord[]; resources?: { items?: ResourceRecord[] } }).resources?.items ??
  (resourcesJson as { items?: ResourceRecord[] }).items ??
  []) as ResourceRecord[];

const rawItems: ResourceRecord[] = entries.length > 0
  ? entries.map((entry) => entry.data as ResourceRecord)
  : fallbackItems;

const localizedItems = rawItems.map((item) => ({
  ...item,
  title: item.title_en || item.title,
  summary: item.summary_en || item.summary,
  subcategory: item.subcategory_en || item.subcategory || 'Uncategorized',
  searchableName: [item.title_en, item.title, item.summary_en, item.summary, item.subcategory_en, item.subcategory].filter(Boolean).join(' '),
}));

const categoryOrder = [
  '实用工具',
  '程序员常用网站',
  '论坛 / 社区',
  '学术资源',
  'AI',
  '资源',
  '娱乐',
  '有趣',
  'VPS / 云服务',
  '域名 / DNS / 建站',
];

const categoryKeys: string[] = [...new Set(localizedItems.map((item) => item.category))].sort((a, b) => {
  const ai = categoryOrder.indexOf(a);
  const bi = categoryOrder.indexOf(b);
  const ax = ai === -1 ? Number.MAX_SAFE_INTEGER : ai;
  const bx = bi === -1 ? Number.MAX_SAFE_INTEGER : bi;
  return ax - bx;
});

const recentItems = localizedItems
  .slice(-RECENT_LIMIT)
  .reverse()
  .map((item) => ({
    ...item,
    category: RECENT_CATEGORY,
    sourceCategoryLabel: enMessages.categoryNames[item.category] ?? item.category,
  }));

const categories: FilterCategory[] = [
  { value: enMessages.ui.allCategory, label: enMessages.ui.allCategory },
  { value: RECENT_CATEGORY, label: enMessages.categoryNames[RECENT_CATEGORY] ?? RECENT_CATEGORY },
  ...categoryKeys.map((key) => ({ value: key, label: enMessages.categoryNames[key] ?? key })),
];

const resourcesByCategory = [
  {
    id: 'cat-recent',
    category: RECENT_CATEGORY,
    categoryLabel: enMessages.categoryNames[RECENT_CATEGORY] ?? RECENT_CATEGORY,
    countLabel: `${recentItems.length} ${enMessages.ui.siteCount}`,
    items: recentItems,
  },
  ...categoryKeys.map((category, index) => {
    const items = localizedItems.filter((item) => item.category === category);
    return {
      id: `cat-${index + 1}`,
      category,
      categoryLabel: enMessages.categoryNames[category] ?? category,
      countLabel: `${items.length} ${enMessages.ui.siteCount}`,
      items,
    };
  }),
];
---

<HomeContent
  messages={enMessages}
  categories={categories}
  resourcesByCategory={resourcesByCategory}
  languageSwitchHref="/"
/>
