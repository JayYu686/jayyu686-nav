---
interface ResourceItem {
  title: string;
  summary: string;
  url: string;
  category: string;
  searchableName?: string;
}

interface Props {
  item: ResourceItem;
  categoryLabel: string;
}

const { item, categoryLabel } = Astro.props;

const getDomain = (url: string) => {
  try {
    return new URL(url).hostname;
  } catch {
    return '';
  }
};
---

<a
  href={item.url}
  target="_blank"
  rel="noopener noreferrer"
  class="card"
  data-cat={item.category}
  data-name={(item.searchableName || item.title || '').toLowerCase()}
>
  <div class="card-top">
    <div class="icon-box">
      <img
        src={`https://icon.horse/icon/${getDomain(item.url)}`}
        alt={item.title}
        loading="lazy"
        decoding="async"
        onerror={`this.onerror=null;this.src='https://www.google.com/s2/favicons?domain=${getDomain(item.url)}&sz=64';`}
      />
    </div>
    <div class="info">
      <h3 class="title">{item.title}</h3>
      <span class="badge">{categoryLabel}</span>
    </div>
  </div>
  <p class="desc">{item.summary}</p>
</a>

<style>
  .card {
    position: relative;
    overflow: hidden;
    -webkit-tap-highlight-color: transparent;
    padding: var(--comp-card-padding, 22px);
    border-radius: var(--comp-card-radius, 20px);
    border: 1px solid var(--card-border);
    background: var(--card-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    text-decoration: none;
    color: var(--text);
    transition: transform var(--motion-fast, 180ms) ease, box-shadow var(--motion-mid, 220ms) ease, border-color var(--motion-mid, 220ms) ease, background var(--motion-mid, 220ms) ease;
    display: flex;
    flex-direction: column;
    gap: var(--comp-card-gap, 14px);
    box-shadow: var(--shadow);
  }

  .card::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: -120%;
    width: 60%;
    pointer-events: none;
    transform: skewX(-18deg);
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.45s ease;
  }

  .card:hover {
    transform: translateY(-3px);
    border-color: var(--line);
    box-shadow: var(--shadow-hover);
    background: var(--panel-active);
  }

  .card:hover::after,
  .card:focus-visible::after {
    left: 150%;
  }

  .card:active {
    transform: translateY(-1px) scale(0.992);
  }

  .card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .icon-box {
    width: var(--ref-icon-shell, 44px);
    height: var(--ref-icon-shell, 44px);
    border-radius: var(--ref-radius-md, 12px);
    background: var(--panel);
    border: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.24);
  }

  .icon-box img {
    width: var(--ref-icon-size, 18px);
    height: var(--ref-icon-size, 18px);
    object-fit: cover;
    border-radius: 4px;
  }

  .info {
    flex: 1;
    min-width: 0;
  }

  .title {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--text);
  }

  .badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: var(--ref-radius-sm, 8px);
    background: rgba(88, 166, 255, 0.1);
    color: var(--accent);
    font-size: 12px;
    margin-top: 4px;
  }

  .desc {
    margin: 0;
    font-size: 14px;
    color: var(--muted);
    line-height: 1.5;
    flex: 1;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    max-height: 3em;
    transition: max-height 0.3s ease;
  }

  .card:hover .desc,
  .card:focus-visible .desc {
    -webkit-line-clamp: unset;
    max-height: 10.5em;
  }

  @media (max-width: 900px) {
    .card {
      padding: 18px;
      border-radius: 18px;
      gap: 12px;
    }

    .title { font-size: 15px; }

    .desc {
      font-size: 13px;
      line-height: 1.45;
    }
  }

  @media (max-width: 640px) {
    .card {
      padding: 14px;
      border-radius: 16px;
      gap: 10px;
    }

    .card-top { gap: 10px; }

    .icon-box {
      width: var(--ref-icon-shell-sm, 38px);
      height: var(--ref-icon-shell-sm, 38px);
      border-radius: 10px;
    }

    .icon-box img {
      width: var(--ref-icon-size-sm, 16px);
      height: var(--ref-icon-size-sm, 16px);
    }

    .title {
      font-size: 14px;
      white-space: normal;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      line-height: 1.3;
      max-height: 2.6em;
    }

    .badge {
      font-size: 11px;
      padding: 2px 7px;
    }

    .desc {
      font-size: 13px;
      max-height: 4.1em;
    }
  }

  @media (hover: none) {
    .card:hover {
      transform: none;
      border-color: var(--card-border);
      box-shadow: var(--shadow);
      background: var(--card-bg);
    }

    .card:hover .desc {
      -webkit-line-clamp: 2;
      max-height: 3em;
    }

    .card:active {
      transform: scale(0.99);
    }
  }
</style>
