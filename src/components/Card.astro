---
interface ResourceItem {
  title: string;
  summary: string;
  url: string;
  category: string;
  subcategory?: string;
  searchableName?: string;
  sourceCategoryLabel?: string;
  iconPath?: string;
}

interface Props {
  item: ResourceItem;
  categoryLabel: string;
}

const { item, categoryLabel } = Astro.props;

const getDomain = (url: string) => {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return '';
  }
};

const hashToHue = (seed: string) => {
  let hash = 0;
  for (let i = 0; i < seed.length; i += 1) {
    hash = ((hash * 31) + seed.charCodeAt(i)) >>> 0;
  }
  return hash % 360;
};

const escapeSvgText = (value: string) => value
  .replace(/&/g, '&amp;')
  .replace(/</g, '&lt;')
  .replace(/>/g, '&gt;')
  .replace(/"/g, '&quot;')
  .replace(/'/g, '&#39;');

const getIconInitial = (seed: string) => {
  const first = Array.from(seed.trim())[0] || 'S';
  return escapeSvgText(first.toUpperCase());
};

const buildGeneratedIconDataUrl = (seed: string) => {
  const hue = hashToHue(seed || 'site');
  const hueAlt = (hue + 34) % 360;
  const initial = getIconInitial(seed || 'S');
  const svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" role="img" aria-label="${initial}"><defs><linearGradient id="g" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="hsl(${hue} 72% 56%)"/><stop offset="100%" stop-color="hsl(${hueAlt} 68% 44%)"/></linearGradient></defs><rect width="64" height="64" rx="14" fill="url(#g)"/><text x="50%" y="54%" dominant-baseline="middle" text-anchor="middle" fill="rgba(255,255,255,0.96)" font-family="Segoe UI,Arial,sans-serif" font-weight="700" font-size="30">${initial}</text></svg>`;
  return `data:image/svg+xml;utf8,${encodeURIComponent(svg)}`;
};

const resolveIconSrc = (resource: ResourceItem) => {
  if (resource.iconPath) {
    return resource.iconPath;
  }
  const seed = getDomain(resource.url) || resource.title || 'site';
  return buildGeneratedIconDataUrl(seed);
};
---

<a
  href={item.url}
  target="_blank"
  rel="noopener noreferrer"
  class="card"
  data-cat={item.category}
  data-subcategory={item.subcategory || ''}
  data-name={(item.searchableName || item.title || '').toLowerCase()}
>
  <div class="card-top">
    <div class="icon-box">
      <img
        src={resolveIconSrc(item)}
        alt=""
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="info">
      <h3 class="title">{item.title}</h3>
      <span class="badge">{categoryLabel}</span>
    </div>
  </div>
  <p class="desc">{item.summary}</p>
</a>

<style>
  .card {
    position: relative;
    overflow: hidden;
    -webkit-tap-highlight-color: transparent;
    padding: var(--comp-card-padding, 22px);
    border-radius: var(--comp-card-radius, 20px);
    border: 1px solid var(--card-border);
    background: var(--card-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    text-decoration: none;
    color: var(--text);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s ease, background 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: var(--comp-card-gap, 14px);
    box-shadow: var(--shadow);
    will-change: transform, box-shadow;
    --card-glow-x: 50%;
    --card-glow-y: 35%;
    --card-glow-opacity: 0;
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    background: radial-gradient(220px circle at var(--card-glow-x) var(--card-glow-y), rgba(255, 255, 255, 0.5) 0%, rgba(178, 210, 255, 0.18) 36%, rgba(56, 74, 106, 0.09) 62%, transparent 78%);
    opacity: var(--card-glow-opacity);
    transition: opacity var(--motion-mid, 220ms) var(--ease-mid, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .card::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: -120%;
    width: 60%;
    pointer-events: none;
    transform: skewX(-18deg);
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left var(--motion-mid, 220ms) var(--ease-mid, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .card:hover {
    transform: translateY(-5px) scale(1.01);
    border-color: var(--line);
    box-shadow: var(--shadow-hover);
    background: var(--panel-active);
    --card-glow-opacity: 0.92;
  }

  .card:hover::after,
  .card:focus-visible::after {
    left: 150%;
  }

  .card:active {
    transform: translateY(0px) scale(0.98);
  }

  .card:focus-visible {
    outline: 2px solid var(--focus-ring, var(--accent));
    outline-offset: 2px;
    box-shadow: var(--shadow-hover), var(--focus-ring-shadow, 0 0 0 3px rgba(88, 166, 255, 0.3));
    border-color: var(--accent);
    --card-glow-opacity: 0.72;
  }

  :global(:root[data-theme='light']) .card::before {
    background: radial-gradient(220px circle at var(--card-glow-x) var(--card-glow-y), rgba(255, 255, 255, 0.62) 0%, rgba(203, 221, 255, 0.2) 34%, rgba(98, 80, 54, 0.08) 62%, transparent 78%);
  }

  :global(:root:not([data-theme='light'])) .card::before {
    background: radial-gradient(210px circle at var(--card-glow-x) var(--card-glow-y), rgba(170, 206, 255, 0.4) 0%, rgba(116, 156, 225, 0.2) 34%, rgba(24, 35, 54, 0.14) 64%, transparent 80%);
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .icon-box {
    width: var(--ref-icon-shell, 44px);
    height: var(--ref-icon-shell, 44px);
    border-radius: var(--ref-radius-md, 12px);
    background: var(--panel);
    border: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.24);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.3s ease;
  }

  .icon-box img {
    width: var(--ref-icon-size, 18px);
    height: var(--ref-icon-size, 18px);
    object-fit: cover;
    border-radius: 4px;
  }

  .info {
    flex: 1;
    min-width: 0;
  }

  .title {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--text);
  }

  .badge {
    display: inline-block;
    padding: 3px 9px;
    border-radius: var(--ref-radius-sm, 8px);
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    color: color-mix(in srgb, var(--accent) 84%, var(--text) 16%);
    border: 1px solid color-mix(in srgb, var(--accent) 24%, transparent);
    font-size: 11px;
    font-weight: 600;
    margin-top: 4px;
  }

  .desc {
    margin: 0;
    font-size: 14px;
    color: var(--text-sub);
    line-height: 1.5;
    flex: 1;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    max-height: 3em;
    transition: max-height var(--motion-mid, 220ms) var(--ease-mid, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .card:hover .icon-box,
  .card:focus-visible .icon-box {
    transform: translateY(-2px) scale(1.08) rotate(-2deg);
  }

  .card:hover .desc,
  .card:focus-visible .desc {
    -webkit-line-clamp: unset;
    max-height: 10.5em;
  }

  @media (max-width: 900px) {
    .card {
      padding: 18px;
      border-radius: 18px;
      gap: 12px;
    }

    .title { font-size: 15px; }

    .desc {
      font-size: 13px;
      line-height: 1.45;
    }
  }

  @media (max-width: 640px) {
    .card {
      padding: 14px;
      border-radius: 16px;
      gap: 10px;
    }

    .card-top { gap: 10px; }

    .icon-box {
      width: var(--ref-icon-shell-sm, 38px);
      height: var(--ref-icon-shell-sm, 38px);
      border-radius: 10px;
    }

    .icon-box img {
      width: var(--ref-icon-size-sm, 16px);
      height: var(--ref-icon-size-sm, 16px);
    }

    .title {
      font-size: 14px;
      white-space: normal;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      line-height: 1.3;
      max-height: 2.6em;
    }

    .badge {
      font-size: 11px;
      padding: 2px 7px;
    }

    .desc {
      font-size: 13px;
      max-height: 4.1em;
    }
  }

  @media (hover: none) {
    .card:hover {
      transform: none;
      border-color: var(--card-border);
      box-shadow: var(--shadow);
      background: var(--card-bg);
      --card-glow-opacity: 0;
    }

    .card:hover .desc {
      -webkit-line-clamp: 2;
      max-height: 3em;
    }

    .card:active {
      transform: scale(0.96);
      background: var(--panel-active);
    }
  }
</style>
