---
import Card from './Card.astro';

interface ResourceItem {
  title: string;
  summary: string;
  url: string;
  category: string;
  subcategory?: string;
  searchableName?: string;
  sourceCategoryLabel?: string;
}

interface Props {
  id: string;
  category: string;
  categoryLabel: string;
  countLabel: string;
  items: ResourceItem[];
}

const { id, category, categoryLabel, countLabel, items } = Astro.props;

const groupedMap = new Map<string, ResourceItem[]>();
for (const item of items) {
  const label = item.subcategory?.trim() || 'Uncategorized';
  if (!groupedMap.has(label)) {
    groupedMap.set(label, []);
  }
  groupedMap.get(label)?.push(item);
}

const groupedItems = Array.from(groupedMap.entries()).map(([label, grouped], index) => ({
  label,
  anchorId: `${id}-sub-${index + 1}`,
  items: grouped,
}));
---

<section class="category-section" id={id} data-category={category}>
  <div class="category-head">
    <h2 class="category-title">{categoryLabel}</h2>
    <span class="category-count">{countLabel}</span>
  </div>
  {groupedItems.map((group) => (
    <div
      class="subcategory-block"
      id={group.anchorId}
      data-subcategory={group.label}
      data-subcategory-anchor={group.anchorId}
    >
      <div class="subcategory-head">
        <h3 class="subcategory-title">{group.label}</h3>
        <span class="subcategory-count">{group.items.length}</span>
      </div>
      <div class="grid">
        {group.items.map((item) => <Card item={item} categoryLabel={item.sourceCategoryLabel || categoryLabel} />)}
      </div>
    </div>
  ))}
</section>

<style>
  .category-section {
    scroll-margin-top: 90px;
    margin-bottom: 24px;
  }

  .category-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 12px;
  }

  .subcategory-block {
    margin-bottom: 16px;
    scroll-margin-top: 96px;
  }

  .subcategory-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
  }

  .subcategory-title {
    margin: 0;
    font-size: 14px;
    color: var(--muted);
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    transition: opacity var(--motion-nav, 240ms) var(--ease-mid, cubic-bezier(0.22, 1, 0.36, 1)), transform var(--motion-nav, 240ms) var(--ease-mid, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .subcategory-count {
    font-size: 12px;
    color: var(--muted);
  }

  .category-title {
    margin: 0;
    font-size: 24px;
    letter-spacing: -0.24px;
    font-weight: 750;
    transition: opacity var(--motion-nav, 240ms) var(--ease-mid, cubic-bezier(0.22, 1, 0.36, 1)), transform var(--motion-nav, 240ms) var(--ease-mid, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .category-count {
    font-size: 13px;
    color: var(--muted);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 18px;
    min-width: 0;
  }

  @media (max-width: 900px) {
    .category-section {
      scroll-margin-top: 78px;
      margin-bottom: 18px;
    }

    .category-title { font-size: 21px; }

    .subcategory-block { margin-bottom: 14px; }

    .subcategory-title { font-size: 14px; }

    .grid {
      grid-template-columns: minmax(0, 1fr);
        gap: 14px;
    }
  }

  @media (max-width: 640px) {
    .category-section {
      scroll-margin-top: 66px;
      margin-bottom: 14px;
    }

    .category-head {
      margin-bottom: 8px;
      flex-wrap: wrap;
      row-gap: 4px;
    }

    .category-title { font-size: 19px; }

    .subcategory-block {
      margin-bottom: 10px;
      scroll-margin-top: 80px;
    }

    .subcategory-head { margin-bottom: 8px; }

    .subcategory-title { font-size: 12px; }

    .subcategory-count { font-size: 11px; }

    .category-count {
      font-size: 12px;
      margin-left: auto;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: 10px;
    }
  }
</style>
